/* Motion: transform/opacity only; ease-out-quart/expo per impeccable */
.page-shell {
  --space-1: 8rpx;
  --space-2: 12rpx;
  --space-3: 16rpx;
  --space-4: 20rpx;
  --space-5: 24rpx;
  --space-6: 32rpx;
  --space-7: 48rpx;
  --accent-lime: #d4ff25;
  --accent-lime-dim: rgba(212, 255, 37, 0.18);
  --accent-lime-glow: rgba(212, 255, 37, 0.32);
  --surface-panel: #16181e;
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.device-shell {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  padding-bottom: var(--space-5);
  box-sizing: border-box;
}

.device-shell::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(
      circle at 14% 16%,
      rgba(183, 255, 43, 0.2),
      transparent 36%
    ),
    radial-gradient(
      circle at 86% 22%,
      rgba(84, 210, 255, 0.2),
      transparent 28%
    ),
    radial-gradient(
      circle at 56% 78%,
      rgba(182, 93, 255, 0.18),
      transparent 34%
    );
}

.topbar {
  position: relative;
  z-index: 2;
  flex: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  padding: 0 var(--space-5);
  margin-bottom: var(--space-2);
  box-sizing: border-box;
}

.topbar-main {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.page-title {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  min-width: 0;
}

.page-title-main {
  color: #f5ffe8;
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: -0.04em;
  line-height: 1.02;
}

.page-title-sub {
  color: rgba(214, 210, 229, 0.68);
  font-size: 20rpx;
  line-height: 1.45;
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.panel-status {
  flex: none;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 172rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(24, 20, 38, 0.72);
  color: #cfd0e4;
  font-size: 20rpx;
  line-height: 1.45;
}

.panel-status-inline {
  flex: none;
  width: 240rpx;
  min-width: 240rpx;
  margin-top: 0;
  padding: 14rpx 14rpx 12rpx;
  gap: 4rpx;
  border-radius: 26rpx;
  border-color: rgba(180, 226, 78, 0.32);
  background: rgba(88, 112, 36, 0.18);
  color: #d9ed92;
  font-size: 22rpx;
}

.topbar-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding-bottom: 2rpx;
}

.ghost-btn,
.preset,
.action-btn,
.chip,
.fullscreen-close,
.fullscreen-toggle,
.plain-link-btn,
.saved-style-delete {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  line-height: 1.25;
  width: auto;
  box-sizing: border-box;
}

/* Override built-in wx-button width/margin defaults */
button:not([size="mini"]),
button.ghost-btn,
button.preset,
button.action-btn,
button.chip,
button.saved-style-delete,
button.plain-link-btn,
button.fullscreen-close,
button.fullscreen-toggle {
  margin-left: 0 !important;
  margin-right: 0 !important;
  width: auto !important;
  min-width: 0 !important;
  line-height: inherit !important;
}

button.chip {
  width: 64rpx !important;
  height: 64rpx !important;
}

.ghost-btn,
.action-btn,
.preset,
.saved-style-delete,
.fullscreen-close,
.fullscreen-toggle {
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  color: #f8efff;
  background: rgba(255, 255, 255, 0.08);
}

.ghost-btn {
  min-height: 60rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
}

.ghost-btn-active {
  color: #0f0a17;
  background: linear-gradient(
    135deg,
    rgba(255, 184, 77, 0.96),
    rgba(240, 93, 176, 0.9)
  );
  border-color: transparent;
}

.ghost-btn-strong {
  color: #0f0a17;
  background: linear-gradient(
    135deg,
    rgba(84, 210, 255, 0.95),
    rgba(240, 93, 176, 0.9)
  );
  border-color: transparent;
}

.editor-stack {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  margin: var(--space-2) var(--space-5) 0;
  border-radius: 36rpx;
  overflow: hidden;
  border: 1rpx solid rgba(212, 255, 37, 0.16);
  box-shadow: 0 22rpx 64rpx rgba(4, 3, 10, 0.48);
}

.preview-section {
  position: relative;
  z-index: 1;
  flex: none;
  padding: 0;
}

.controls-scroll {
  flex: 1;
  height: 0;
  width: 100%;
}

.preview-card {
  position: relative;
  min-height: 38vh;
  border-radius: 0;
  overflow: hidden;
  border: 0;
  box-shadow: none;
  transition:
    transform 180ms cubic-bezier(0.25, 1, 0.5, 1),
    opacity 220ms cubic-bezier(0.25, 1, 0.5, 1);
}

.preview-card::after {
  content: "";
  position: absolute;
  inset: -40% -60%;
  pointer-events: none;
  background: linear-gradient(
    115deg,
    transparent 42%,
    rgba(215, 255, 31, 0.07) 50%,
    transparent 58%
  );
  animation: stageSweep 7s cubic-bezier(0.25, 1, 0.5, 1) infinite;
  z-index: 1;
}

.preview-card-pulse {
  opacity: 0.98;
}

.editor-stack-pulse {
  box-shadow:
    0 22rpx 64rpx rgba(4, 3, 10, 0.48),
    0 0 48rpx rgba(212, 255, 37, 0.14);
}

.preview-badge {
  position: absolute;
  top: 22rpx;
  left: 22rpx;
  z-index: 3;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(212, 255, 37, 0.38);
  background: rgba(8, 10, 14, 0.82);
  color: #e8ffb0;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
}

.preview-badge-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #d4ff25;
  box-shadow: 0 0 0 6rpx rgba(212, 255, 37, 0.2);
  animation: liveDot 2.4s ease-out infinite;
}

.preview-fade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 140rpx;
  z-index: 2;
  pointer-events: none;
  background: linear-gradient(
    180deg,
    rgba(22, 24, 30, 0) 0%,
    rgba(22, 24, 30, 0.72) 58%,
    var(--surface-panel) 100%
  );
}

.preview-cta {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 108rpx;
  z-index: 3;
  display: flex;
  justify-content: center;
  pointer-events: none;
  color: #e8ffb0;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-shadow: 0 0 24rpx rgba(212, 255, 37, 0.38);
}

.preview-card-press {
  opacity: 0.96;
}

.preview-card::before,
.fullscreen-shell::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.02) 1rpx, transparent 1rpx);
  background-size: 34rpx 34rpx;
}

.preview-meta,
.preview-hint,
.panel-head,
.field-head,
.action-row {
  position: relative;
  z-index: 2;
}

.preview-meta {
  position: absolute;
  top: 22rpx;
  left: 22rpx;
  right: 22rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(21, 17, 30, 0.68);
  color: #dee0f2;
  font-size: 20rpx;
}

.meta-pill-live {
  color: #ffc2e7;
}

.meta-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #f05db0;
  box-shadow: 0 0 0 8rpx rgba(240, 93, 176, 0.18);
  animation: pulse 2.2s ease-out infinite;
}

.preview-stage,
.fullscreen-stage {
  position: relative;
  height: 100%;
  overflow: hidden;
}

.preview-stage {
  min-height: 38vh;
  padding: 52rpx 28rpx 120rpx;
}

.fullscreen-stage {
  position: absolute;
  inset: 0;
}

.fullscreen-stage .ambient-track,
.fullscreen-stage .hero-track {
  display: none;
}

.ambient-track,
.hero-track {
  position: absolute;
  will-change: transform;
  animation-name: rise;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}

.ambient-track {
  width: 28%;
  bottom: -90%;
  font-size: 26rpx;
  line-height: 1.72;
  white-space: pre-wrap;
  opacity: 0.9;
}

.ambient-track-left {
  left: 26rpx;
  text-align: left;
}

.ambient-track-right {
  right: 26rpx;
  text-align: right;
}

.hero-track {
  left: 40rpx;
  right: 40rpx;
  bottom: -45%;
  font-weight: 700;
  line-height: 1.1;
  text-align: center;
  word-break: break-all;
  white-space: normal;
}

.preview-stage .hero-track {
  top: 50%;
  bottom: auto;
  transform: translateY(-50%);
  animation: none;
  opacity: 1;
  transition:
    opacity 220ms cubic-bezier(0.25, 1, 0.5, 1),
    transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-track-pulse {
  transform: translateY(-50%) scale(1.03);
}

.hero-track-full {
  left: 64rpx;
  right: 64rpx;
  bottom: -40%;
  white-space: pre-line;
  line-height: 1;
}

.fullscreen-text-wrap {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.2em;
  text-align: center;
  width: auto;
  max-height: 92%;
  animation-name: none;
  animation-duration: 0s;
  animation-iteration-count: 0;
  will-change: transform;
}

.fullscreen-active:not(.fullscreen-entering) .fullscreen-text-wrap {
  animation: neonBreathe 3.2s ease-in-out infinite;
}

.fullscreen-loop-track {
  position: absolute;
  left: 50%;
  top: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: auto;
  will-change: transform;
}

.fullscreen-loop-unit {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.fullscreen-loop-spacer {
  flex: none;
  width: 2rpx;
}

.fullscreen-looping {
  animation-name: fullscreenLoopScroll;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}

.fullscreen-glyph {
  display: block;
  line-height: 1;
  transform: rotate(90deg);
  transform-origin: center;
  white-space: nowrap;
}

.preview-hint {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  bottom: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hint-copy {
  color: #ebedf9;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.hint-action {
  color: #c8cae2;
  font-size: 20rpx;
}

.controls-panel {
  position: relative;
  z-index: 2;
  flex: none;
  margin: 0;
  padding: var(--space-2) var(--space-5) calc(env(safe-area-inset-bottom) + var(--space-6));
  border-radius: 0;
  border: 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  background: var(--surface-panel);
  box-shadow: none;
}

.controls-panel::before {
  content: "";
  position: absolute;
  top: 0;
  left: 12%;
  right: 12%;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(212, 255, 37, 0.22),
    transparent
  );
  pointer-events: none;
}

.panel-handle {
  width: 72rpx;
  height: 6rpx;
  margin: var(--space-1) auto var(--space-3);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
}

.panel-head {
  margin-bottom: 18rpx;
}

.panel-head-main {
  display: flex;
  flex-direction: row;
  gap: 14rpx;
  align-items: flex-start;
  justify-content: space-between;
}

.panel-copy-block {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.panel-title {
  color: #fff;

  letter-spacing: -0.03em;

  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 8rpx;
}

.panel-copy,
.micro-copy,
.saved-style-meta,
.saved-style-text {
  color: #a9b2c3;
  font-size: 26rpx;
  line-height: 1.65;
}

.control-stack {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.control-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.control-group-hero {
  gap: 0;
}

.control-group-tune {
  gap: var(--space-3);
}

.field {
  padding: var(--space-4);
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
}

.field-strong {
  margin-top: 0;
  padding: var(--space-5) var(--space-4);
  border-color: rgba(212, 255, 37, 0.2);
  background: linear-gradient(
    180deg,
    rgba(212, 255, 37, 0.06),
    rgba(255, 255, 255, 0.02)
  );
}

.field-flat {
  padding: var(--space-3);
  background: rgba(255, 255, 255, 0.025);
}

.field-compact {
  padding: var(--space-4) var(--space-4) var(--space-3);
}

.field-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.field-label,
.field-value {
  font-size: 22rpx;
}

.field-label {
  color: #9aa6bc;
  flex: 1;
  min-width: 0;
  letter-spacing: 0.06em;
}

.field-value {
  color: #e8ffb0;
  flex: none;
  max-width: 44%;
  font-size: 28rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: right;
}

.text-input {
  width: 100%;
  min-height: 96rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 255, 37, 0.16);
  background: rgba(18, 22, 32, 0.94);
  color: #f8ffef;
  font-size: 46rpx;
  font-weight: 800;
}

.slider-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-3);
}

.slider-cell {
  border-radius: 16rpx;
  padding: var(--space-3);
  background: rgba(0, 0, 0, 0.12);
}

.slider-cell .field-head {
  margin-bottom: 6rpx;
}

.slider-cell .field-label,
.slider-cell .field-value {
  color: rgba(154, 166, 188, 0.92);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.custom-slider {
  position: relative;
  width: 100%;
  height: 40rpx;
  margin: 8rpx 0 2rpx;
}

.custom-slider-track {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  height: 10rpx;
  transform: translateY(-50%);
  border-radius: 999rpx;
  background: linear-gradient(90deg, #d4e73b 0%, #0097a7 100%);
}

.custom-slider-thumb {
  position: absolute;
  top: 50%;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(12, 14, 18, 0.72);
  background: #f2eedf;
  transform: translate(-50%, -50%);
  z-index: 2;
  transition:
    left 90ms linear,
    box-shadow 160ms ease-out;
}

.palette {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
  align-items: center;
  justify-content: flex-start;
}

.chip {
  min-width: 64rpx;
  min-height: 64rpx;
  padding: 0;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
  flex: none;
  transition:
    transform 180ms cubic-bezier(0.25, 1, 0.5, 1),
    box-shadow 200ms cubic-bezier(0.25, 1, 0.5, 1),
    border-color 200ms cubic-bezier(0.25, 1, 0.5, 1);
}

.chip-press {
  transform: scale(0.92);
}

.chip-active {
  box-shadow:
    inset 0 0 0 10rpx rgba(8, 10, 16, 0.94),
    0 0 0 2rpx rgba(255, 255, 255, 0.24),
    0 0 28rpx rgba(215, 255, 31, 0.28);
  animation: chipPop 360ms cubic-bezier(0.16, 1, 0.3, 1);
}

.preset-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-3);
}

.preset {
  min-height: 80rpx;
  width: 100%;
  min-width: 0;
  flex: none;
  padding: 0 var(--space-2);
  border-radius: 999rpx;
  color: #c9d0de;
  font-size: 26rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.12);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition:
    transform 180ms cubic-bezier(0.25, 1, 0.5, 1),
    color 200ms cubic-bezier(0.25, 1, 0.5, 1),
    background 200ms cubic-bezier(0.25, 1, 0.5, 1),
    border-color 200ms cubic-bezier(0.25, 1, 0.5, 1),
    box-shadow 200ms cubic-bezier(0.25, 1, 0.5, 1);
}

.preset-press {
  transform: scale(0.97);
}

.preset-active {
  color: #12170e;
  font-weight: 800;
  background: linear-gradient(135deg, #d4ff25, #b8e61a);
  border-color: rgba(212, 255, 37, 0.55);
  box-shadow: 0 10rpx 28rpx rgba(212, 255, 37, 0.28);
}

.saved-style-list {
  display: grid;
  gap: 10rpx;
}

.saved-style-card {
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  padding: 12rpx;
  background: rgba(15, 12, 24, 0.44);
}

.saved-style-head {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.saved-style-accent {
  width: 10rpx;
  align-self: stretch;
  border-radius: 999rpx;
}

.saved-style-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.saved-style-name {
  color: #fff4ff;
  font-size: 25rpx;
  font-weight: 700;
}

.saved-style-meta,
.saved-style-text {
  font-size: 21rpx;
  line-height: 1.48;
}

.saved-style-delete {
  min-width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  font-size: 22rpx;
}

.empty-state {
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.05);
  color: #bbb8d2;
  font-size: 22rpx;
  line-height: 1.58;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-3);
  margin-top: 0;
  padding-top: var(--space-6);
  border-top: 1rpx solid rgba(212, 255, 37, 0.12);
}

.action-btn {
  min-height: 104rpx;
  width: 100%;
  min-width: 0;
  padding: 0 18rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #9eacc4;
  background: rgba(14, 17, 24, 0.96);
  border-color: rgba(255, 255, 255, 0.1);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition:
    transform 150ms cubic-bezier(0.25, 1, 0.5, 1),
    opacity 150ms cubic-bezier(0.25, 1, 0.5, 1);
}

.action-btn-press {
  transform: scale(0.97);
  opacity: 0.9;
}

.action-btn-primary {
  color: #12170e;
  font-size: 32rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #d4ff25 0%, #c0eb1f 100%);
  border-color: transparent;
  box-shadow: 0 12rpx 36rpx rgba(212, 255, 37, 0.34);
}

.secondary-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
}

.plain-link-btn {
  min-height: 48rpx;
  padding: 0 2rpx;
  color: #c3c1d9;
  font-size: 23rpx;
  background: transparent;
}

.micro-copy {
  margin-top: 10rpx;
  font-size: 24rpx;
  word-break: break-word;
}

.fullscreen-layer {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: stretch;
  justify-content: stretch;
  padding: 0;
  background: #05070b;
  opacity: 0;
  visibility: hidden;
  transition:
    opacity 260ms cubic-bezier(0.16, 1, 0.3, 1),
    visibility 260ms cubic-bezier(0.16, 1, 0.3, 1);
}

.fullscreen-active {
  opacity: 1;
  visibility: visible;
}

.fullscreen-entering .fullscreen-shell {
  animation: fullscreenShellIn 320ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.fullscreen-entering .fullscreen-text-wrap:not(.fullscreen-text-wrap-alt) {
  animation: fullscreenTextIn 380ms cubic-bezier(0.16, 1, 0.3, 1) both;
}

.fullscreen-active .fullscreen-close,
.fullscreen-active .fullscreen-toggle {
  opacity: 1;
  transform: translateY(0);
}

.fullscreen-close,
.fullscreen-toggle {
  opacity: 0;
  transform: translateY(20rpx);
  transition:
    opacity 220ms cubic-bezier(0.25, 1, 0.5, 1),
    transform 220ms cubic-bezier(0.25, 1, 0.5, 1);
  transition-delay: 140ms;
}

.fullscreen-btn-press {
  transform: scale(0.96) translateY(0) !important;
  opacity: 0.88 !important;
}

.fullscreen-shell {
  position: relative;
  width: 100vw;
  max-width: none;
  height: 100vh;
  border-radius: 0;
  overflow: hidden;
  border: 0;
  box-shadow: none;
}

.pinch-guide {
  position: absolute;
  inset: 0;
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 56rpx 40rpx;
  background: rgba(6, 8, 12, 0.78);
  opacity: 0;
  overflow: hidden;
  transition: opacity 320ms cubic-bezier(0.16, 1, 0.3, 1);
}

.pinch-guide-visible {
  opacity: 1;
}

.pinch-guide-veil {
  position: absolute;
  inset: 0;
  background:
  linear-gradient(rgba(212, 255, 37, 0.04) 1rpx, transparent 1rpx),
  linear-gradient(90deg, rgba(212, 255, 37, 0.04) 1rpx, transparent 1rpx);
  background-size: 56rpx 56rpx;
  opacity: 0.55;
  pointer-events: none;
}

.pinch-guide-ghost {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.pinch-guide-ghost-column {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  max-height: 72vh;
  opacity: 0.42;
  filter: blur(10rpx);
  transform: scale(1.08);
}

.pinch-guide-ghost-glyph {
  font-size: 112rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 0.08em;
}

.pinch-guide-card {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  width: 100%;
  max-width: 560rpx;
  padding: 48rpx 40rpx 36rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(212, 255, 37, 0.2);
  background: rgba(16, 18, 24, 0.94);
  box-shadow:
    0 28rpx 72rpx rgba(0, 0, 0, 0.52),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 0 0 1rpx rgba(212, 255, 37, 0.06),
    0 0 56rpx rgba(212, 255, 37, 0.1);
  transform: translateY(28rpx) scale(0.95);
  transition:
    transform 360ms cubic-bezier(0.16, 1, 0.3, 1),
    opacity 360ms cubic-bezier(0.16, 1, 0.3, 1);
}

.pinch-guide-visible .pinch-guide-card {
  transform: translateY(0) scale(1);
}

.pinch-guide-stage {
  position: relative;
  width: 248rpx;
  height: 196rpx;
  margin-bottom: 8rpx;
}

.pinch-guide-ripple {
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  transform: translate(-50%, -50%);
  animation: pinchRipple 2.8s cubic-bezier(0.16, 1, 0.3, 1) infinite;
}

.pinch-guide-ripple-1 {
  width: 92rpx;
  height: 92rpx;
}

.pinch-guide-ripple-2 {
  width: 148rpx;
  height: 148rpx;
  opacity: 0.72;
  animation-delay: 0.32s;
}

.pinch-guide-ripple-3 {
  width: 204rpx;
  height: 204rpx;
  opacity: 0.42;
  animation-delay: 0.64s;
}

.pinch-finger {
  position: absolute;
  top: 50%;
  width: 54rpx;
  height: 54rpx;
  margin-top: -27rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 38% 32%, #fffffd, #f3f5ec 52%, #e2e8d8);
  box-shadow:
    0 10rpx 28rpx rgba(0, 0, 0, 0.32),
    0 0 28rpx rgba(255, 255, 255, 0.55),
    0 0 52rpx rgba(212, 255, 37, 0.2);
}

.pinch-finger-left {
  left: 50%;
  margin-left: -62rpx;
  z-index: 2;
  animation: pinchFingerLeft 2.8s cubic-bezier(0.16, 1, 0.3, 1) infinite;
}

.pinch-finger-right {
  left: 50%;
  margin-left: 8rpx;
  z-index: 3;
  animation: pinchFingerRight 2.8s cubic-bezier(0.16, 1, 0.3, 1) infinite;
}

.pinch-guide-title {
  color: #f7f8f5;
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 0.01em;
  line-height: 1.2;
}

.pinch-guide-sub {
  color: rgba(196, 200, 210, 0.84);
  font-size: 26rpx;
  line-height: 1.45;
  text-align: center;
}

.pinch-guide-hint {
  margin-top: 6rpx;
  color: rgba(140, 148, 164, 0.9);
  font-size: 22rpx;
  line-height: 1.4;
  text-align: center;
}

@keyframes pinchFingerLeft {
  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }

  50% {
    transform: translate(34rpx, 0) scale(0.96);
  }
}

@keyframes pinchFingerRight {
  0%,
  100% {
    transform: translate(0, 0) scale(1);
  }

  50% {
    transform: translate(-34rpx, 0) scale(0.96);
  }
}

@keyframes pinchRipple {
  0%,
  100% {
    opacity: 0.22;
    transform: translate(-50%, -50%) scale(0.94);
  }

  50% {
    opacity: 0.62;
    transform: translate(-50%, -50%) scale(1);
  }
}

.fullscreen-close {
  position: absolute;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  right: 24rpx;
  z-index: 3;
  min-height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  background: rgba(8, 14, 20, 0.64);
  border-color: rgba(255, 255, 255, 0.28);
}

.fullscreen-toggle {
  position: absolute;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  z-index: 3;
  min-height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  background: rgba(8, 14, 20, 0.64);
  border-color: rgba(255, 255, 255, 0.28);
}

@keyframes rise {
  0% {
    transform: translate3d(0, 120%, 0);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  85% {
    opacity: 1;
  }
  100% {
    transform: translate3d(0, -170%, 0);
    opacity: 0;
  }
}

@keyframes pulse {
  0%,
  100% {
    box-shadow: 0 0 0 8rpx rgba(240, 93, 176, 0.18);
  }
  50% {
    box-shadow: 0 0 0 14rpx rgba(240, 93, 176, 0.08);
  }
}

@keyframes fullscreenLoopScroll {
  0% {
    transform: translate(-50%, 100vh);
  }

  100% {
    transform: translate(-50%, calc(-100% + 100vh));
  }
}

@keyframes fullscreenShellIn {
  from {
    opacity: 0;
    transform: scale(0.975);
  }

  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes fullscreenTextIn {
  from {
    opacity: 0;
    transform: translate(-50%, -46%) scale(0.92);
  }

  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

@keyframes stageSweep {
  0%,
  72% {
    transform: translateX(-18%) rotate(0deg);
    opacity: 0;
  }

  82% {
    opacity: 1;
  }

  100% {
    transform: translateX(22%) rotate(0deg);
    opacity: 0;
  }
}

@keyframes liveDot {
  0%,
  100% {
    opacity: 1;
    box-shadow: 0 0 0 6rpx rgba(212, 255, 37, 0.2);
  }

  50% {
    opacity: 0.72;
    box-shadow: 0 0 0 10rpx rgba(212, 255, 37, 0.08);
  }
}

@keyframes chipPop {
  0% {
    transform: scale(1);
  }

  45% {
    transform: scale(1.12);
  }

  100% {
    transform: scale(1);
  }
}

@keyframes neonBreathe {
  0%,
  100% {
    opacity: 1;
  }

  50% {
    opacity: 0.92;
  }
}

@media (prefers-reduced-motion: reduce) {
  .ambient-track,
  .hero-track,
  .meta-dot,
  .preview-badge-dot,
  .preview-card::after,
  .chip-active,
  .fullscreen-text-wrap,
  .fullscreen-loop-track,
  .fullscreen-looping {
    animation: none !important;
  }

  .hero-track-pulse {
    transform: translateY(-50%);
  }

  .preview-card-pulse {
    box-shadow: 0 16rpx 48rpx rgba(4, 3, 10, 0.44);
  }

  .fullscreen-entering .fullscreen-shell,
  .fullscreen-entering .fullscreen-text-wrap {
    animation: none !important;
  }

  .preview-card,
  .preview-stage .hero-track,
  .chip,
  .preset,
  .action-btn,
  .custom-slider-thumb,
  .fullscreen-layer,
  .fullscreen-close,
  .fullscreen-toggle {
    transition-duration: 0.01ms !important;
  }

  .pinch-guide-ripple,
  .pinch-finger-left,
  .pinch-finger-right {
    animation: none !important;
  }

  .pinch-guide-ghost-column {
    filter: none;
    opacity: 0.28;
  }

  .pinch-finger-left {
    transform: translate(34rpx, 0) scale(0.96);
  }

  .pinch-finger-right {
    transform: translate(-34rpx, 0) scale(0.96);
  }
}

@media (max-width: 360px) {
  .topbar-main {
    flex-direction: column;
  }

  .panel-status,
  .panel-status-inline {
    width: 100%;
    min-width: 0;
  }

  .panel-head-main {
    flex-direction: column;
  }

  .slider-grid {
    grid-template-columns: 1fr;
  }

  .action-row {
    grid-template-columns: 1fr;
  }

  .editor-stack {
    margin-left: var(--space-3);
    margin-right: var(--space-3);
  }

  .preview-card,
  .preview-stage {
    min-height: 34vh;
  }

  .preview-stage {
    padding-bottom: 100rpx;
  }
}
