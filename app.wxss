page {
  min-height: 100%;
  background:
    radial-gradient(circle at 20% 0%, rgba(183, 255, 43, 0.18), transparent 24%),
    radial-gradient(circle at 84% 14%, rgba(0, 213, 255, 0.14), transparent 22%),
    radial-gradient(circle at 58% 82%, rgba(216, 75, 255, 0.12), transparent 24%),
    linear-gradient(180deg, #15161b, #0d0e12);
  color: #f1efe6;
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  font-size: inherit;
  font-family: inherit;
  font-weight: inherit;
  line-height: inherit;
}

button::after {
  border: 0;
}

.doc-page {
  min-height: 100vh;
  padding: 48rpx 40rpx 80rpx;
}

.doc-hero {
  margin-bottom: 48rpx;
}

.doc-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 20rpx;
}

.doc-copy {
  display: block;
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(241, 239, 230, 0.78);
}

.doc-section {
  margin-bottom: 40rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.doc-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #d4ff25;
}

.doc-list text {
  display: block;
  font-size: 26rpx;
  line-height: 1.8;
  color: rgba(241, 239, 230, 0.86);
  margin-bottom: 8rpx;
}
